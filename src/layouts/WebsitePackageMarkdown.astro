          <!-- <h2>FAQ</h2>

          <h2>CTA</h2>
          <h2>CONTACT</h2> -->

          <div class="mt-5 my-5 py-[55px] pt-2 opacity-80 text-lg">
            <div class="">
              <slot />
            </div>
            <BackBtn />
          </div>
        </div>
        <Footer />
      </section>
    </div>
  </div>
</MainLayout>
