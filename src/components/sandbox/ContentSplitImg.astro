---
export interface Props {
  attentionParagraph: string;
  interestParagraph: string;
  desireParagraph: string;
  actionParagraph: string;
  websiteUrl?: string;
  img: string;
  img2: string;
  btn1: string;
  btn2: string;
  btn1Link: string;
  btn2Link: string;
}

const {
  attentionParagraph,
  interestParagraph,
  desireParagraph,
  actionParagraph,
  websiteUrl,
  // img,
  // img2,
  // btn1,
  btn2,
  // btn1Link,
  // btn2Link,
} = Astro.props as Props;
---

<div id="wrapper" class="p-1">
  <div id="" class="flex">
    <div id="sq1" class="">
      <img
        src="https://images.pexels.com/photos/11598957/pexels-photo-11598957.jpeg?_gl=1*akdlkc*_ga*MTA5MDE3MzI2MS4xNzU4MjUwMDM4*_ga_8JE65Q40S6*czE3NzMyNjc2MDQkbzQxJGcwJHQxNzczMjY3NjA0JGo2MCRsMCRoMA.."
        alt="a photo of a desert landscape with a cactus and mountains in the background"
        class="w-1/2 h-auto object-cover rounded-lg"
      />
    </div>
    <div id="sq2" class="2xl:p-5 px-3">
      <div id="content" class="bg-test1 md:p-1 mb-5">
        <!-- -1) attention -->
        <!-- -2) interest -->
        <!-- -3) desire -->
        <!-- -4) action -->
        <h1 id="attentionParagraph" class="md:text-4xl text-2xl my-5">
          {attentionParagraph}
        </h1>

        <div id="padding-left" class="text-xl font-thin pt-1 pl-1 space-y-10">
          <p id="" class="bg-">
            {interestParagraph}
          </p>
          <p class="bg-">
            {desireParagraph}
          </p>
          <p class="bg-">
            {"<"}
            {actionParagraph}
            {">"}
          </p>
        </div>
      </div>
      <div id="btns-wrapper" class="pl-2 mt-[50px]">
        <div id="btns-container-flex" class="flex space-x-4">
          <!-- <button
            id="dynamic-btn"
            class="text-cerulean opacity-85 hover:opacity-100 sq-styles bg- text-"
          >
            <a href={btn1Link}>
              {btn1}
            </a>
          </button> -->

          <button
            id="contact-btn"
            class="bg-cerulean text-white text-lg opacity-85 hover:opacity-100 sq-styles"
          >
            <a href="mailto:elsahovey@gmail.com">
              {btn2}
            </a>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
