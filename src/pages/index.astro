---
import MainLayout from "../layouts/MainLayout.astro";
import Contact from "../components/sections/Contact.astro";
import Footer from "../components/Footer.astro";
import TableContents from "../components/sections/TableContents.astro";
// import TechApplicationCard from "../components/TechApplicationCard.astro";
import WebsitePackageCard from "../components/WebsitePackageCard.astro";
import Hero from "../components/sections/Hero.astro";
// const techApplications = await Astro.glob("./techApplications/*.md");
const websitePackages = await Astro.glob("./websitePackages/*.md");
---

<MainLayout>
  <Hero
    title="Start Here"
    paragraph="Web Design Inspired by Southern California Aesthetics. websites inspired by desert colors, and palm springs modernism styles... from someone who's lived the desert life for a near decade! explore website packages... v"
  />
  <div
    id="BUILD-AUTHORITY-case-studies-grid"
    class="bg- ml-5 mr-[50px] px-5 grid 2xl:grid-cols-2 gap-5 my- bg-"
  >
    {
      websitePackages.map((caseStudy) => (
        <WebsitePackageCard
          no={caseStudy.frontmatter.no}
          title={caseStudy.frontmatter.title}
          image={caseStudy.frontmatter.image.url}
          alt={caseStudy.frontmatter.image.alt}
          url={caseStudy.url}
          testItem1={caseStudy.frontmatter.testItem1}
          language={caseStudy.frontmatter.language}
          backend={caseStudy.frontmatter.backend}
        />
      ))
    }
  </div>
  <!-- WHAT ALL BUILDS ALSO CAN OFFER, ELABORATE ON THINGS vvvv -->
  <TableContents />
  <!-- </div> -->
  <!-- <div id="expand-on-my-websites-wrapper" class="bg- pb-5 px-5 mx-5">
            <div
              id="expand-on-my-websites-card"
              class="grid xl:grid-cols-3 lg:grid-cols-2 grid-cols-1 gap-x-1 pl-2 pb-5"
            >
              {
                techApplications.map((help) => (
                  <TechApplicationCard
                    no={help.frontmatter.no}
                    image={help.frontmatter.image.url}
                    alt={help.frontmatter.image.alt}
                    url={help.url}
                    testItem1={help.frontmatter.testItem1}
                    language={help.frontmatter.language}
                    backend={help.frontmatter.backend}
                  />
                ))
              }
            </div>
          </div> -->
  <!-- </div> -->
  <Contact />
  <Footer />
</MainLayout>
